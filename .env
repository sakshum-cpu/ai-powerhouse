# OpenAI Configuration
OPENAI_API_KEY=your_api_key_here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Application Configuration
DEBUG=False
LOG_LEVEL=INFO
APP_NAME=AI Powerhouse

# Database Configuration
DB_URL=sqlite:///./ai_powerhouse.db

# Agent Configuration
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT=300

# Chatbot Configuration
CHATBOT_MEMORY_SIZE=10
CHATBOT_CONTEXT_WINDOW=5

# Code Generator Configuration
CODE_GEN_TIMEOUT=30
CODE_GEN_SANDBOX=True
